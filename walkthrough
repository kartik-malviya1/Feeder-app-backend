## Connecting From Expo App

### Step 1: Find Your Local IP

Your server is running at: **`http://192.168.1.20:3000`** (shown in server startup logs).

> [!CAUTION]
> **Never use `localhost` or `127.0.0.1` from Expo on a real device!** Those refer to the phone itself, not your computer. Always use your machine's LAN IP (e.g., `192.168.x.x`).

### Step 2: Set Up API Base URL

```typescript
// config/api.ts
const API_BASE = __DEV__
  ? 'http://192.168.1.20:3000'   // ← Your computer's IP
  : 'https://your-production-url.com';

const WS_BASE = __DEV__
  ? 'ws://192.168.1.20:3000/ws'
  : 'wss://your-production-url.com/ws';

export { API_BASE, WS_BASE };
```

### Step 3: Fetch API Examples

```typescript
// Login
const login = async (phone: string, password: string) => {
  const res = await fetch(`${API_BASE}/auth/login`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      type: 'user',
      identifier: phone,
      password,
    }),
  });
  const data = await res.json();
  // Save data.token to AsyncStorage
  return data;
};

// Request a ride (with JWT)
const requestRide = async (token: string, pickup: {lat: number, lng: number}, drop: {lat: number, lng: number}) => {
  const res = await fetch(`${API_BASE}/rides/request`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${token}`,
    },
    body: JSON.stringify({
      pickupLat: pickup.lat,
      pickupLng: pickup.lng,
      dropLat: drop.lat,
      dropLng: drop.lng,
      price: 150,
      paymentMode: 'CASH',
    }),
  });
  return await res.json();
};
```

### Step 4: WebSocket Connection from Expo

```typescript
// hooks/useWebSocket.ts
import { useEffect, useRef } from 'react';
import { WS_BASE } from '../config/api';

export function useWebSocket(userId: number, role: 'user' | 'driver', onMessage: (data: any) => void) {
  const ws = useRef<WebSocket | null>(null);

  useEffect(() => {
    // 1. Connect
    ws.current = new WebSocket(WS_BASE);

    ws.current.onopen = () => {
      console.log('WebSocket connected');
      // 2. Register
      ws.current?.send(JSON.stringify({
        type: 'REGISTER',
        id: userId,
        role,
      }));
    };

    ws.current.onmessage = (event) => {
      const data = JSON.parse(event.data);
      console.log('WS received:', data);
      onMessage(data);
    };

    ws.current.onerror = (error) => {
      console.log('WS error:', error);
    };

    ws.current.onclose = () => {
      console.log('WS closed — reconnecting in 3s...');
      setTimeout(() => {
        // Reconnect logic
      }, 3000);
    };

    return () => ws.current?.close();
  }, [userId, role]);

  // Function to send driver location
  const sendLocation = (lat: number, lng: number) => {
    if (ws.current?.readyState === WebSocket.OPEN) {
      ws.current.send(JSON.stringify({
        type: 'LOCATION_UPDATE',
        role: 'driver',
        id: userId,
        lat,
        lng,
      }));
    }
  };

  return { sendLocation };
}
```

**Usage in a component:**
```typescript
// In your RideScreen or DriverScreen
const { sendLocation } = useWebSocket(user.id, 'user', (data) => {
  switch (data.event) {
    case 'RIDE_ACCEPTED':
      Alert.alert('Ride Accepted!', `Driver: ${data.driverName}\nOTP: ${data.otp}`);
      break;
    case 'DRIVER_LOCATION':
      // Update driver marker on map
      setDriverPosition({ lat: data.lat, lng: data.lng });
      break;
    case 'RIDE_COMPLETED':
      Alert.alert('Ride completed!');
      break;
  }
});
```

